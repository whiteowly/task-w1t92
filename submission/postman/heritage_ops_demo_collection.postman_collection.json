{
  "info": {
    "name": "Heritage Ops API Demo Flow",
    "description": "Ordered end-to-end demo flow for Heritage Ops backend.\n\nPrerequisites:\n- API running at {{baseUrl}}\n- Organization and users already exist (admin/member/group leader/reviewer)\n- All users belong to {{organizationSlug}} with expected roles\n\nRun requests in order from top to bottom. IDs/tokens are captured into collection variables for later requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00. Auth Context Bootstrap",
      "description": "Capture role-specific sessions and user IDs used by later folders.",
      "item": [
        {
          "name": "Login as Member",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organization_slug\": \"{{organizationSlug}}\",\n  \"username\": \"{{memberUsername}}\",\n  \"password\": \"{{memberPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login/",
            "description": "Stores memberSessionKey for member operations."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.response.to.have.status(200);",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('memberSessionKey', data.session_key);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Auth Me as Member",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Session-Key",
                "value": "{{memberSessionKey}}"
