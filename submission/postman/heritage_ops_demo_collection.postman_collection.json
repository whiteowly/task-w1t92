            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requester\": \"{{groupLeaderUserId}}\",\n  \"amount\": \"300.00\"\n}"
            },
            "url": "{{baseUrl}}/finance/withdrawal-requests/",
            "description": "Expected: pending_review because amount > 250."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.response.to.have.status(201);",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('highWithdrawalId', String(data.id));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Reviewer Approves High-Value Withdrawal",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Session-Key", "value": "{{reviewerSessionKey}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"decision\": \"approved\",\n  \"review_notes\": \"Demo reviewer approval\"\n}"
            },
            "url": "{{baseUrl}}/finance/withdrawal-requests/{{highWithdrawalId}}/review/"
          }
        }
      ]
    }
  ],
